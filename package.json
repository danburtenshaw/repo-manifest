{
  "name": "repo-manifest",
  "version": "1.0.0",
  "private": true,
  "description": "Keep GitHub repo settings in sync with a declarative config file",
  "homepage": "https://github.com/danburtenshaw/repo-manifest",
  "bugs": "https://github.com/danburtenshaw/repo-manifest/issues",
  "license": "MIT",
  "author": "Dan Burtenshaw",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danburtenshaw/repo-manifest.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "check": "vp check",
    "fix": "vp check --fix",
    "test": "vp test",
    "build": "vp pack src/index.ts -f esm --target node24 --platform node --out-dir dist",
    "emit-schema": "node scripts/emit-schema.ts"
  },
  "devDependencies": {
    "@actions/core": "3.0.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@octokit/rest": "22.0.1",
    "@types/node": "25.6.0",
    "lefthook": "2.1.6",
    "ts-pattern": "5.9.0",
    "typescript": "6.0.3",
    "vite-plus": "0.1.18",
    "vitest": "4.1.4",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
